{
    "name": "jedi-interviews",
    "version": "1.0.0",
    "description": "A personal Windows desktop assistant for meetings and interviews — a transparent, always-on-top, keyboard-controlled overlay.",
    "type": "module",
    "main": "./out/main/index.js",
    "author": "rodrigo-gomez@idexx.com",
    "license": "UNLICENSED",
    "private": true,
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "dev": "electron-vite dev",
        "build": "electron-vite build",
        "preview": "electron-vite preview",
        "start": "electron-vite preview",
        "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
        "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
        "typecheck": "npm run typecheck:node && npm run typecheck:web",
        "lint": "oxlint .",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "vitest run",
        "package": "electron-vite build && electron-builder --win",
        "verify:secret": "electron-vite build --config electron.vite.verify.config.ts && electron out/verify/verify-secret.js",
        "verify:keys": "electron-vite build --config electron.vite.verify-keys.config.ts && electron out/verify-keys/verify-api-keys.js",
        "rebuild": "electron-rebuild -f -w uiohook-napi,native-recorder-nodejs"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "0.104.2",
        "@deepgram/sdk": "5.4.0",
        "electron-store": "11.0.2",
        "native-recorder-nodejs": "1.2.0",
        "uiohook-napi": "1.5.5",
        "ulid": "^3.0.2"
    },
    "devDependencies": {
        "@electron/rebuild": "^4.0.1",
        "@types/node": "22.10.5",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "4.3.4",
        "electron": "35.7.5",
        "electron-builder": "26.15.3",
        "electron-vite": "5.0.0",
        "oxlint": "1.70.0",
        "prettier": "3.4.2",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "typescript": "5.9.3",
        "vite": "6.0.7",
        "vitest": "3.2.4"
    }
}
