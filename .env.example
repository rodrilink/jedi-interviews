# Local dev secrets template (D-08 / SET-03).
#
# Copy this file to `.env` (gitignored) and fill in the real keys. The keys are read in the
# Electron main process only — after loadDotenvFile() — passed to the gateway constructors, and
# never logged, emitted, or sent over IPC. Phase 6's safeStorage-backed entry will replace this
# source without touching the gateways.

# Deepgram streaming STT key (Phase 4). Source: Deepgram Console -> API keys.
DEEPGRAM_API_KEY=

# Anthropic Claude key (Phase 5, Answer/Talking-points modes). Source: Anthropic Console ->
# Settings -> API keys. Without it, an AI hotkey shows `AI error: missing API key` inline.
ANTHROPIC_API_KEY=
